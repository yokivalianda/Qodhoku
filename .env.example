# Environment Variables — QodhoKu Backend

# ─── Turso (LibSQL) ───────────────────────────────────────
# Dapatkan dengan: turso db show qodhoku
TURSO_URL=libsql://your-db-name-your-org.turso.io

# Dapatkan dengan: turso db tokens create qodhoku
TURSO_AUTH_TOKEN=your-turso-auth-token-here

# ─── JWT ─────────────────────────────────────────────────
# Ganti dengan string random panjang (min 32 karakter)
JWT_SECRET=change-this-to-a-very-long-random-secret-string

# ─── Server ──────────────────────────────────────────────
PORT=3001

# ─── Frontend (Vite) ─────────────────────────────────────
# URL backend yang sudah di-deploy (untuk production)
# Contoh Railway: https://qodhoku-production.up.railway.app/api
# Contoh Render:  https://qodhoku.onrender.com/api
# Kosongkan untuk development (otomatis pakai localhost:3001)
VITE_API_URL=https://your-backend-url.railway.app/api
